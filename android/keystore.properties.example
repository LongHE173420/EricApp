# Copy this file to android/keystore.properties and replace the sample values.
# The keystore file itself should stay out of git, for example at android/app/upload-keystore.jks

STORE_FILE=app/upload-keystore.jks
STORE_TYPE=PKCS12
STORE_PASSWORD=replace-with-your-store-password
KEY_ALIAS=upload
KEY_PASSWORD=replace-with-your-key-password
